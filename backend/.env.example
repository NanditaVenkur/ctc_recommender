# Choose which LLM backend the chatbot should use.
# Options: groq, radeon
LLM_PROVIDER=radeon

# Groq provider. Use this when LLM_PROVIDER=groq.
GROQ_API_KEY=""
GROQ_MODEL=llama-3.3-70b-versatile

# Radeon / AMD provider. Use this when LLM_PROVIDER=radeon.
# This expects an OpenAI-compatible chat completions endpoint.
# Example local endpoint: http://127.0.0.1:8001/v1
RADEON_BASE_URL=https://radeon-global.anruicloud.com/instances/hf-180-1a071167/proxy/8000/v1
RADEON_API_KEY=not-needed
RADEON_MODEL="Qwen/Qwen2.5-7B-Instruct"

